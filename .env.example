# ════════════════════════════════════════════════════════════════════
# CuanBot v4 - Environment Configuration
# Salin file ini jadi .env lalu isi nilainya.
#
# File ini HANYA berisi:
#   1. Kredensial / API key (secrets)
#   2. Toggle DRY_RUN
#
# Semua parameter strategi (TP, SL, trailing, cooldown, scoring, dll)
# di-tune di config.py (class Config) — BUKAN di sini.
# ════════════════════════════════════════════════════════════════════

# ── Mode ─────────────────────────────────────────────────────────────
# true  = simulasi (tidak ada transaksi nyata)
# false = LIVE trading
DRY_RUN=true

# ── Tokocrypto API Credentials ───────────────────────────────────────
# DARI: https://www.tokocrypto.com/user/api-management
# PENTING: JANGAN share key ini ke siapapun! Aktifkan IP Whitelist.
TOKOCRYPTO_API_KEY=your_api_key_here
TOKOCRYPTO_SECRET_KEY=your_secret_key_here

# ── Notifications (opsional tapi sangat direkomendasikan) ─────────────
# Biarkan TELEGRAM_BOT_TOKEN kosong/terkomenen untuk menonaktifkan notif.
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── AI Filter (opsional, Z.ai GLM) ───────────────────────────────────
# Biarkan kosong = AI nonaktif, sinyal indikator diloloskan langsung
# (dengan filter skor >= AI_FALLBACK_MIN_SCORE, lihat config.py).
# URL & model default sudah di-set di config.py (ZAI_API_URL, ZAI_MODEL).
# ZAI_API_KEY=your_zai_api_key_here
