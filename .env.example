# ════════════════════════════════════════════════════════════════════
# CuanBot v4 - Environment Configuration (Tokocrypto IDR)
# Salin file ini jadi .env lalu isi nilainya.
# ════════════════════════════════════════════════════════════════════

# ── Tokocrypto API Credentials ───────────────────────────────────────
# DARI: https://www.tokocrypto.com/user/api-management
# PENTING: JANGAN share key ini ke siapapun! Aktifkan IP Whitelist.
TOKOCRYPTO_API_KEY=your_api_key_here
TOKOCRYPTO_SECRET_KEY=your_secret_key_here

# ── Mode ─────────────────────────────────────────────────────────────
# true = simulasi (tidak ada transaksi nyata) | false = LIVE trading
DRY_RUN=true

# ── Modal & Dynamic Capital Deployment ──────────────────────────────
# Base currency fix IDR (Tokocrypto). Tidak perlu set manual.
INITIAL_TRADE_AMOUNT=10000        # Fallback/display (sizing utama pakai saldo riil)
MIN_ORDER_IDR=10000               # Minimum notional Tokocrypto (~10k IDR)
WORKING_CAPITAL_PCT=0.85          # 85% saldo diputar, 15% buffer fee/slippage
MIN_CAPITAL_PER_POSITION=50000    # Modal ideal per posisi (penentu jml posisi dinamis)
AUTO_COMPOUND=true                # true = track realized PnL (statistik)

# ── Risk & Profit (%) ────────────────────────────────────────────────
TAKE_PROFIT_PERCENT=2.5           # Auto-sell kalau profit 2.5% (fee-aware)
STOP_LOSS_PERCENT=1.8             # Auto-sell kalau rugi 1.8% (fee-aware)
MAX_TRADES_PER_DAY=10             # Max trade per hari
COOLDOWN_MINUTES=5                # Jeda antar trade
MAX_OPEN_POSITIONS=5              # Cap maksimal posisi paralel (dinamis by saldo)
POSITION_TIMEOUT_HOURS=6          # Auto-sell posisi nyangkut

# ── Safety Nets ─────────────────────────────────────────────────────
DAILY_LOSS_LIMIT_PCT=3.0          # Stop trading hari itu kalau rugi >= 3% saldo awal
WIN_RATE_GUARD_TRADES=20          # Cek win rate dari N trade terakhir
WIN_RATE_GUARD_MIN=45             # Pause kalau win rate < 45%

# ── Trailing Stop ────────────────────────────────────────────────────
TRAILING_STOP_ENABLED=true        # Aktif/nonaktifkan trailing stop
TRAILING_PERCENT=0.5              # Jarak trailing dari high (0.5%)
TRAILING_ACTIVATION=0.8           # Trailing aktif setelah profit 0.8%

# ── Scoring ──────────────────────────────────────────────────────────
MIN_SCORE_TO_BUY=55               # Skor minimum untuk sinyal BUY
MIN_SCORE_TO_HOLD=38              # Skor <= ini = SELL

# ── Emergency Stop ───────────────────────────────────────────────────
EMERGENCY_STOP_LOSSES=3           # Pause setelah X rugi berturut-turut
EMERGENCY_PAUSE_HOURS=2           # Durasi pause (jam)

# ── Notifications (opsional tapi sangat direkomendasikan) ────────────
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# TELEGRAM_CHAT_ID=your_telegram_chat_id
NOTIFY_SCAN=false                 # Notif hasil scan top coin

# ── AI Filter (opsional, Z.ai GLM-5.2) ──────────────────────────────
# Kosongkan ZAI_API_KEY = AI nonaktif, sinyal indikator diloloskan langsung
# ZAI_API_KEY=your_zai_api_key_here
ZAI_API_URL=https://api.z.ai/api/paas/v4/

# ── State File ───────────────────────────────────────────────────────
STATE_FILE=state.json
